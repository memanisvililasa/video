{
  "name": "videosave",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": "24.18.0",
    "npm": "11.6.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "node scripts/build-worker.mjs",
    "build:web-readiness": "node scripts/build-web-readiness.mjs",
    "build:cutover-readiness": "node scripts/build-cutover-readiness.mjs",
    "build:production-smoke": "node scripts/build-production-smoke.mjs",
    "build:release": "node scripts/build-release.mjs && node scripts/package-release.mjs",
    "verify:release": "node scripts/verify-release.mjs .release-dist/release",
    "stage:release:artifact": "node scripts/stage-release-artifact.mjs",
    "package:release": "node scripts/package-release.mjs",
    "test:release": "vitest run --project unit tests/release tests/security/rate-limit.test.ts && node scripts/test-standalone-release.mjs",
    "volume:admin": "node scripts/durable-volume-admin.mjs",
    "release:deploy": "node scripts/release-deployment.mjs",
    "smoke:production:no-egress": "npm run build:production-smoke --silent && node .production-smoke-dist/main.mjs --no-egress",
    "smoke:production:controlled-egress": "npm run build:production-smoke --silent && node .production-smoke-dist/main.mjs --controlled-egress",
    "verify:deployment": "node scripts/verify-deployment-templates.mjs",
    "verify:deployment:linux": "node scripts/verify-linux-deployment.mjs",
    "verify:observability": "node scripts/verify-observability-documentation.mjs",
    "test:release:linux": "node scripts/test-linux-installed-release.mjs",
    "audit:repository": "node scripts/audit-repository-secrets.mjs",
    "audit:observability:bundle": "node scripts/audit-observability-bundle.mjs",
    "test:observability": "vitest run --project unit tests/observability tests/deployment/templates.test.ts tests/release/environment-templates.test.ts",
    "test:deployment:unit": "vitest run --project unit tests/deployment",
    "test:deployment:smoke": "vitest run --config vitest.postgres.config.ts tests/postgres/production-smoke.integration.ts",
    "test:deployment": "npm run test:deployment:unit && npm run test:deployment:smoke && npm run verify:deployment",
    "test:c1:unit": "vitest run --project unit tests/config/application-role-config.test.ts tests/security/rate-limit.test.ts tests/deployment tests/release",
    "test:c1:postgres": "vitest run --config vitest.postgres.config.ts tests/postgres/job-repository.integration.ts tests/postgres/web-readiness.integration.ts tests/postgres/media-worker.integration.ts tests/postgres/production-cutover.integration.ts tests/postgres/production-smoke.integration.ts",
    "test:c1": "npm run test:c1:unit && npm run test:c1:postgres && npm run verify:deployment && npm run audit:repository",
    "start": "next start",
    "start:worker": "node .worker-dist/main.mjs",
    "check:worker": "node .worker-dist/main.mjs --check",
    "check:web": "npm run build:web-readiness --silent && node .web-readiness-dist/main.mjs",
    "check:web:test": "vitest run --config vitest.postgres.config.ts tests/postgres/web-readiness.integration.ts",
    "check:cutover": "npm run build:cutover-readiness --silent && node .cutover-readiness-dist/main.mjs",
    "check:cutover:test": "vitest run --config vitest.postgres.config.ts tests/postgres/production-cutover.integration.ts",
    "lint": "next lint",
    "test": "npm run test:all",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:postgres": "vitest run --config vitest.postgres.config.ts",
    "test:worker": "vitest run --project unit tests/worker tests/config/media-worker-config.test.ts",
    "test:worker:smoke": "vitest run --config vitest.worker-smoke.config.ts",
    "test:all": "npm run test:unit && npm run test:browser",
    "db:migrate": "node scripts/postgres-migrations.mjs apply",
    "db:migrate:status": "node scripts/postgres-migrations.mjs status",
    "db:migrate:test": "node scripts/postgres-migrations.mjs apply --test",
    "db:migrate:test:status": "node scripts/postgres-migrations.mjs status --test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitest/browser-playwright": "4.1.10",
    "autoprefixer": "10.4.20",
    "esbuild": "0.28.1",
    "playwright": "1.59.0",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.16",
    "typescript": "5.7.2",
    "vite": "8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-react": "2.2.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
