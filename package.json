    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitest/browser-playwright": "4.1.10",
    "autoprefixer": "10.4.20",
    "playwright": "1.59.0",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.16",
    "typescript": "5.7.2",
    "vite": "8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-react": "2.2.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
