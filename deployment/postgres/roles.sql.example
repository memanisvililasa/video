\set ON_ERROR_STOP on

-- Cluster bootstrap only. Required psql identifier variables:
--   migration_role, web_role, worker_role
-- Recommended Phase A values are videosave_migration, videosave_web, videosave_worker.
-- Passwords are assigned separately through the operator secret channel.
CREATE ROLE :"migration_role" LOGIN NOINHERIT NOSUPERUSER NOCREATEDB NOCREATEROLE NOREPLICATION CONNECTION LIMIT 2;
CREATE ROLE :"web_role" LOGIN NOINHERIT NOSUPERUSER NOCREATEDB NOCREATEROLE NOREPLICATION CONNECTION LIMIT 10;
CREATE ROLE :"worker_role" LOGIN NOINHERIT NOSUPERUSER NOCREATEDB NOCREATEROLE NOREPLICATION CONNECTION LIMIT 10;
