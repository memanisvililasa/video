# Copy outside the release to /etc/videosave/web.env and set mode 0600 or 0640.
# This template contains placeholders only. Never commit the populated file.
NODE_ENV=production
APP_PROCESS_ROLE=web
HOSTNAME=127.0.0.1
PORT=3000
OBSERVABILITY_ENABLED=true
OBSERVABILITY_LOG_LEVEL=info
OBSERVABILITY_READINESS_TIMEOUT_MS=5000
OBSERVABILITY_METRICS_MAX_BYTES=65536

JOB_REPOSITORY_BACKEND=postgres
DATABASE_URL=postgresql://<web-role>:<password>@<database-host>/<database>
POSTGRES_SSL_MODE=require
POSTGRES_POOL_MAX=5
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_STATEMENT_TIMEOUT_MS=15000
POSTGRES_QUERY_TIMEOUT_MS=15000
POSTGRES_IDLE_TIMEOUT_MS=30000

MEDIA_STORAGE_BACKEND=durable-volume
MEDIA_STORAGE_ROOT=/var/lib/videosave/media
# Non-secret identity must match the authority line in the v2 .videosave-volume marker.
MEDIA_STORAGE_AUTHORITY_ID=<32-lowercase-hex-authority-id>
MEDIA_STORAGE_MAX_JOB_BYTES=1073741824
MEDIA_STORAGE_MAX_OUTPUT_BYTES=524288000
MEDIA_FINAL_TTL_SECONDS=3600
MEDIA_STORAGE_LOW_DISK_BYTES=1073741824
MEDIA_CLEANUP_BATCH_SIZE=100
JOB_ACTIVE_TTL_SECONDS=86400

# Trusted only when B2 makes Nginx the sole ingress and overwrites X-VideoSave-Client-IP.
TRUST_PROXY_MODE=nginx-single-host
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30
MAX_FILE_SIZE_MB=500
MAX_VIDEO_DURATION_MINUTES=30
# Required before any public platform-page extractor is enabled.
YT_DLP_PATH=/usr/local/bin/yt-dlp
