# Copy outside the release to /etc/videosave/worker.env and set mode 0600 or 0640.
NODE_ENV=production
APP_PROCESS_ROLE=worker
JOB_REPOSITORY_BACKEND=postgres
DATABASE_URL=postgresql://<worker-role>:<password>@<database-host>/<database>
POSTGRES_SSL_MODE=require
POSTGRES_POOL_MAX=5
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_STATEMENT_TIMEOUT_MS=15000
POSTGRES_QUERY_TIMEOUT_MS=15000
POSTGRES_IDLE_TIMEOUT_MS=30000

MEDIA_STORAGE_BACKEND=durable-volume
MEDIA_STORAGE_ROOT=/var/lib/videosave/media
# Non-secret identity must match the authority line in the v2 .videosave-volume marker.
MEDIA_STORAGE_AUTHORITY_ID=<32-lowercase-hex-authority-id>
MEDIA_STORAGE_MAX_JOB_BYTES=1073741824
MEDIA_STORAGE_MAX_OUTPUT_BYTES=524288000
MEDIA_FINAL_TTL_SECONDS=3600
MEDIA_STORAGE_LOW_DISK_BYTES=1073741824
MEDIA_CLEANUP_BATCH_SIZE=100

WORKER_ID_PREFIX=worker
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=1000
WORKER_PROGRESS_INTERVAL_MS=1000
WORKER_SHUTDOWN_GRACE_MS=30000
WORKER_ATTEMPT_TIMEOUT_MS=1200000
WORKER_METADATA_TIMEOUT_SECONDS=10
WORKER_DB_LOSS_GRACE_MS=5000
WORKER_CANCELLATION_POLL_INTERVAL_MS=2000
JOB_LEASE_DURATION_MS=60000
JOB_LEASE_RENEW_INTERVAL_MS=15000
JOB_RECOVERY_ENABLED=true
JOB_RECOVERY_INTERVAL_MS=15000
JOB_RECOVERY_BATCH_SIZE=100
JOB_RETRY_BACKOFF_BASE_MS=5000
JOB_RETRY_BACKOFF_MAX_MS=300000
JOB_ACTIVE_TTL_SECONDS=86400
JOB_MAX_RETRIES=3
MEDIA_RECONCILIATION_INTERVAL_MS=60000
MEDIA_ORPHAN_GRACE_MS=60000
JOB_EXPIRATION_BATCH_SIZE=100
WORKER_ELECTION_RETRY_INTERVAL_MS=5000
WORKER_STORAGE_HEALTH_INTERVAL_MS=5000
JOB_EXPIRED_RETENTION_SECONDS=86400

FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
DOWNLOAD_TIMEOUT_SECONDS=120
FFPROBE_TIMEOUT_SECONDS=15
FFMPEG_TIMEOUT_SECONDS=900
FFMPEG_KILL_GRACE_SECONDS=2
FFMPEG_THREADS=2
MAX_FILE_SIZE_MB=500
MAX_VIDEO_DURATION_MINUTES=30
