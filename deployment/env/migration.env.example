# Copy outside the release to /etc/videosave/migration.env and set mode 0600 or 0640.
NODE_ENV=production
APP_PROCESS_ROLE=migration
DATABASE_URL=postgresql://<migration-role>:<password>@<database-host>/<database>
POSTGRES_SSL_MODE=require
# Optional for a private CA; the file must be root-owned and outside the release.
# NODE_EXTRA_CA_CERTS=/etc/videosave/postgresql-ca.pem
